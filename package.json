{
  "name": "phoenix-ai",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:dev": "pnpm --filter @phoenix-ai/api dev",
    "api:dev:worker": "pnpm --filter @phoenix-ai/api dev:worker",
    "example:task": "node --experimental-strip-types examples/run-task.ts",
    "example:analytics": "node --experimental-strip-types examples/generate-analytics.ts",
    "quality:benchmarks": "node --experimental-strip-types scripts/run-benchmarks.ts",
    "quality:regressions": "node --experimental-strip-types scripts/run-regressions.ts",
    "quality:report": "node --experimental-strip-types scripts/generate-quality-report.ts",
    "studio:dev": "pnpm --filter @phoenix-ai/studio dev",
    "studio:build": "pnpm --filter @phoenix-ai/studio build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
