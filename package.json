{
    "name":  "phoenix-ai",
    "version":  "1.0.0-rc1",
    "private":  true,
    "packageManager":  "pnpm@11.9.0",
    "type":  "module",
    "scripts":  {
                    "api:dev":  "pnpm --filter @phoenix-ai/api dev",
                    "api:dev:worker":  "pnpm --filter @phoenix-ai/api dev:worker",
                    "example:task":  "node --experimental-strip-types examples/run-task.ts",
                    "example:analytics":  "node --experimental-strip-types examples/generate-analytics.ts",
                    "quality:benchmarks":  "node --experimental-strip-types scripts/run-benchmarks.ts",
                    "quality:regressions":  "node --experimental-strip-types scripts/run-regressions.ts",
                    "quality:report":  "node --experimental-strip-types scripts/generate-quality-report.ts",
                    "observability:test":  "node --experimental-strip-types scripts/test-sanitization.ts",
                    "studio:dev":  "pnpm --filter @phoenix-ai/studio dev",
                    "studio:build":  "pnpm --filter @phoenix-ai/studio build",
                    "openapi:generate":  "node --experimental-strip-types scripts/generate-openapi.ts",
                    "openapi:validate":  "node --experimental-strip-types scripts/validate-openapi.ts",
                    "sdk:build":  "node --experimental-strip-types packages/phoenix-sdk/src/index.ts",
                    "sdk:test":  "node --experimental-strip-types packages/phoenix-sdk/src/test.ts",
                    "backup":  "node --experimental-strip-types scripts/backup.ts",
                    "restore":  "node --experimental-strip-types scripts/restore.ts",
                    "backup-all":  "node --experimental-strip-types scripts/backup-all.ts",
                    "restore-all":  "node --experimental-strip-types scripts/restore-all.ts",
                    "health-check":  "node --experimental-strip-types scripts/health-check.ts",
                    "preflight":  "node --experimental-strip-types scripts/preflight.ts",
                    "post-upgrade":  "node --experimental-strip-types scripts/post-upgrade.ts",
                    "integrity:check":  "node --experimental-strip-types scripts/integrity-check.ts",
                    "diagnostics":  "node --experimental-strip-types scripts/diagnostics.ts"
                    ,"identity:migrate":  "node --experimental-strip-types scripts/migrate-identity-v1.ts"
                    ,"identity:test":  "node --experimental-strip-types scripts/test-identity.ts"
                    ,"identity:test:security":  "node --experimental-strip-types scripts/test-identity-security.ts"
                    ,"secrets:migrate":  "node --experimental-strip-types scripts/migrate-secrets-v1.ts"
                    ,"secrets:test":  "node --experimental-strip-types scripts/test-secrets.ts"
                    ,"secrets:test:security":  "node --experimental-strip-types scripts/test-secrets-security.ts"
                    ,"secrets:rotate:test":  "node --experimental-strip-types scripts/test-secrets.ts"
                    ,"api-keys:test":  "node --experimental-strip-types scripts/test-api-keys.ts"
                    ,"backup:secrets":  "node --experimental-strip-types scripts/backup-secrets.ts"
                    ,"restore:secrets":  "node --experimental-strip-types scripts/restore-secrets.ts"
                    ,"plugins:test":  "node --experimental-strip-types scripts/test-plugins.ts"
                    ,"plugins:test:security":  "node --experimental-strip-types scripts/test-plugins-security.ts"
                    ,"workflows:test":  "node --experimental-strip-types scripts/test-workflows.ts"
                    ,"events:test":  "node --experimental-strip-types scripts/test-event-bus.ts"
                    ,"knowledge:test":  "node --experimental-strip-types scripts/test-knowledge-graph.ts"
                    ,"models:test":  "node --experimental-strip-types scripts/test-model-orchestrator.ts"
                    ,"cost:test":  "node --experimental-strip-types scripts/test-cost-intelligence.ts"
                },
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "dependencies":  {
                       "@phoenix-ai/config":  "workspace:*",
                       "@phoenix-ai/cost-intelligence":  "workspace:*",
                       "@phoenix-ai/event-bus":  "workspace:*",
                       "@phoenix-ai/identity":  "workspace:*",
                       "@phoenix-ai/knowledge-graph":  "workspace:*",
                       "@phoenix-ai/model-orchestrator":  "workspace:*",
                       "@phoenix-ai/plugin-sdk":  "workspace:*",
                       "@phoenix-ai/secrets":  "workspace:*",
                       "@phoenix-ai/version":  "workspace:*",
                       "@phoenix-ai/workflow-engine":  "workspace:*",
                       "@phoenix-ai/workspace":  "workspace:*"
                   }
}
