{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-ai.local/schemas/response.schema.json",
  "title": "Phoenix Runtime Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "execution_id",
    "execution_time",
    "pipeline",
    "score",
    "quality",
    "execution",
    "output"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "execution_id": {
      "type": "string",
      "format": "uuid"
    },
    "execution_time": {
      "type": "number",
      "minimum": 0
    },
    "pipeline": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "attempts",
        "failed_agents",
        "final_score"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "attempts": {
          "type": "number",
          "minimum": 0
        },
        "failed_agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "agent",
              "reason"
            ],
            "properties": {
              "agent": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "final_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "provider",
        "duration_ms",
        "agents",
        "tokens",
        "cost",
        "persisted"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "provider": {
          "type": "string"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "provider",
              "attempts",
              "duration_ms",
              "score",
              "tokens",
              "cost"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "success",
                  "error"
                ]
              },
              "provider": {
                "type": "string"
              },
              "attempts": {
                "type": "number",
                "minimum": 0
              },
              "duration_ms": {
                "type": "number",
                "minimum": 0
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "tokens": {
                "$ref": "#/$defs/tokens"
              },
              "cost": {
                "$ref": "#/$defs/cost"
              },
              "error": {
                "type": "string"
              }
            }
          }
        },
        "tokens": {
          "$ref": "#/$defs/tokens"
        },
        "cost": {
          "$ref": "#/$defs/cost"
        },
        "persisted": {
          "type": "boolean"
        },
        "storage": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object"
    },
    "error": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "output",
        "total"
      ],
      "properties": {
        "input": {
          "type": "number",
          "minimum": 0
        },
        "output": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "estimated"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "enum": [
            "USD"
          ]
        },
        "estimated": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
